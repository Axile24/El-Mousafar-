# Copy to backend/.env and restart the API:
#   cp .env.example .env
#
# Docker Compose : variables SMTP / EMAIL_SIMULATE dans le .env à la racine du dépôt
# (voir ../.env.example) — injectées dans le conteneur « api ».
#
# Secret utilisé par l’API pour les futurs usages internes (ex. liens invités).
ADMIN_INVITE_SECRET=choose-a-long-random-secret

# OTP par e-mail — envoi réel : SMTP_HOST + EMAIL_FROM (auth si requis). EMAIL_SIMULATE=0 .
# Test sans boîte mail : EMAIL_SIMULATE=1 (code dans devOtp + logs).
EMAIL_SIMULATE=0
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
# SMS_OTP_PEPPER=change-me-long-random

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=el_mousafar
# Set true for Azure Database for MySQL or any server requiring TLS.
MYSQL_SSL=false

# Optional
# PORT=4000
# PUBLIC_APP_URL=http://127.0.0.1:5173
