# Copy to backend/.env and restart the API:
#   cp .env.example .env
#
# Same value must be entered in the « code d’invitation » field when registering as admin.

ADMIN_INVITE_SECRET=choose-a-long-random-secret

# MySQL database. The API creates the database/tables if the user has permission.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=el_mousafar
# Set true for Azure Database for MySQL or any server requiring TLS.
MYSQL_SSL=false

# Optional
# PORT=4000
# PUBLIC_APP_URL=http://127.0.0.1:5173
