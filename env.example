# Local frontend override (optional)
# VITE_API_BASE=http://127.0.0.1:4000

# Map basemap (optional). Default: OpenFreeMap vector (HTTPS).
# VITE_MAP_STYLE=carto
# VITE_MAP_STYLE_URL=https://example.com/my-style.json

# Backend reads backend/.env automatically (see backend/.env.example).
# Copy that file to backend/.env and set at least:
#
# ADMIN_INVITE_SECRET=your-secret-here
#
# Without it, admin self-signup shows:
# « Inscription administrateur désactivée : le serveur n’a pas de code d’invitation ».

# Backend runtime (optional; can live in backend/.env instead)
# PORT=4000
# SQLITE_PATH=./backend/data/mousafar.sqlite
# PUBLIC_APP_URL=http://127.0.0.1:5173
