# Local frontend override (optional)
# VITE_API_BASE=http://127.0.0.1:4000

# Backend runtime
# PORT=4000
# SQLITE_PATH=./backend/data/mousafar.sqlite
# PUBLIC_APP_URL=http://127.0.0.1:5173

# Admin signup gate
# ADMIN_INVITE_SECRET=replace-with-strong-secret

# SMTP (optional for email verification mails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
# SMTP_FROM=no-reply@example.com
