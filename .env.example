# Variables lues par Docker Compose (fichier « .env » à la racine, à côté de docker-compose*.yml).
# Copier : cp .env.example .env  puis renseigner. Redémarrer : docker compose … up --build
#
# OTP par e-mail — sans fichier .env, Docker Compose utilise déjà EMAIL_SIMULATE=1 (code dans l’API + logs).
# Pour de vrais e-mails : EMAIL_SIMULATE=0 et renseignez SMTP_* + EMAIL_FROM .
#
EMAIL_SIMULATE=1
# EMAIL_SIMULATE=0
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
#
# Optionnel : secret HMAC partagé pour les codes OTP (changements de serveur).
# SMS_OTP_PEPPER=
